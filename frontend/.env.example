# API Configuration - Development
VITE_API_URL=http://localhost:8000/api

# Authentication URLs
VITE_SIGNUP_URL=http://localhost:8000/api/user/signup
VITE_LOGIN_URL=http://localhost:8000/api/user/login
VITE_LOGOUT_URL=http://localhost:8000/api/user/logout
VITE_CHECKAUTH_URL=http://localhost:8000/api/user/auth-check

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLELOGIN_URL=http://localhost:8000/api/user/googleLogin

# User APIs
VITE_BASE_URL=http://localhost:8000/api/user
VITE_GETDATA_URL=http://localhost:8000/api/user/get-data

# Contacts APIs
VITE_ADDCONTACT_URL=http://localhost:8000/api/contacts/addcontact
VITE_DELETECONTACT_URL=http://localhost:8000/api/contacts/delete-contact
VITE_GETCONTACTS_URL=http://localhost:8000/api/contacts

# Emergency Contacts APIs
VITE_EMERGENCY_CONTACTS_URL=http://localhost:8000/api/emergency-contacts

# Location APIs
VITE_LOCATION_URL=http://localhost:8000/api/location

# SOS APIs
VITE_SOS_URL=http://localhost:8000/api/sos

# Review APIs
VITE_ADDREVIEW_URL=http://localhost:8000/api/reviews/addreview
VITE_GETREVIEWS_URL=http://localhost:8000/api/reviews/allreviews

# Contact Us Form
VITE_CONTACT_US_URL=http://localhost:8000/api/contact-us

# Notification APIs
VITE_NOTIFICATION_URL=http://localhost:8000/api/notifications

# Admin APIs
VITE_ADMIN_URL=http://localhost:8000/api/admin

# Feature Flags
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_SMS_NOTIFICATIONS=true
VITE_ENABLE_WHATSAPP_NOTIFICATIONS=true
VITE_ENABLE_LOCATION_TRACKING=true

# Application
VITE_APP_NAME=Raksha
VITE_NODE_ENV=development
VITE_EMERGENCY_URL = "https://woman-safety-app.onrender.com/api/contacts/emergency"
VITE_ADDREVIEW_URL = "https://woman-safety-app.onrender.com/api/reviews/addreview"
VITE_GETALLREVIEWS_URL = "https://woman-safety-app.onrender.com/api/reviews/allreviews"
VITE_GOOGLE_MAPS_KEY = "YOUR_GOOGLE_MAPS_API_KEY"
VITE_ADDPROFILEPHOTO_URL = "https://woman-safety-app.onrender.com/api/profile/add-photo"
VITE_UPDATEUSERNAME_URL = "https://woman-safety-app.onrender.com/api/profile/update-name"
VITE_UPDATEEMAIL_URL = "https://woman-safety-app.onrender.com/api/profile/update-email"
VITE_UPDATEPASSWORD_URL = "https://woman-safety-app.onrender.com/api/profile/update-password"